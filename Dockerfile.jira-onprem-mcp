# JIRA On-Premise MCP Server — Docker image
# Runs the custom JIRA on-prem MCP server that provides JIRA issue
# tracking tools via the Model Context Protocol (Streamable HTTP transport).
#
# Auth: Uses Basic Auth (JIRA_USERNAME + JIRA_PASSWORD) internally.
# The Nexus app connects to the /mcp endpoint without forwarding credentials.

FROM node:22-alpine AS base
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Install dependencies (only production deps needed)
FROM base AS deps
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

# Build the MCP server
FROM base AS builder
COPY package.json package-lock.json ./
RUN npm ci
COPY tsconfig.mcp.json ./
COPY src/mcp-servers/jira-onprem/ ./src/mcp-servers/jira-onprem/
COPY src/lib/jira/api.ts ./src/lib/jira/api.ts
RUN npx tsc --project tsconfig.mcp.json

# Production runner
FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production

RUN addgroup --system --gid 1001 mcpserver
RUN adduser --system --uid 1001 mcpuser

# Copy compiled output + production deps
COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/dist-mcp ./dist-mcp
COPY --from=builder /app/package.json ./

USER mcpuser

EXPOSE 8080
ENV MCP_PORT=8080

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

CMD ["node", "dist-mcp/mcp-servers/jira-onprem/start.js"]
